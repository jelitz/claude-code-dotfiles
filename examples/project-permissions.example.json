{
  "_comment": "특정 프로젝트(Railway 기반 배포 운영)에서 실제로 사용하던 권한 allowlist 예시. 이런 프로젝트 종속 권한은 전역 ~/.claude/settings.json 이 아니라 해당 프로젝트의 .claude/settings.json 또는 .claude/settings.local.json 의 permissions.allow 에 두는 것을 권장. 전역에는 범용 권한만 유지.",
  "permissions": {
    "allow": [
      "Bash(railway status *)",
      "Bash(railway logs *)",
      "Bash(railway service list *)",
      "Bash(railway service status *)",
      "Bash(pnpm typecheck)",
      "PowerShell(railway whoami)",
      "PowerShell(railway whoami *)",
      "PowerShell(railway status)",
      "PowerShell(railway status *)",
      "PowerShell(railway environment)",
      "PowerShell(railway environment *)",
      "PowerShell(railway variables)",
      "PowerShell(railway variables -k*)",
      "PowerShell(railway variables --kv*)",
      "PowerShell(railway variable list*)",
      "PowerShell(railway volume list*)",
      "PowerShell(railway deployment list*)",
      "PowerShell(railway service list*)",
      "PowerShell(railway service status*)",
      "PowerShell(railway logs*)",
      "PowerShell(railway --help*)",
      "PowerShell(railway * --help*)",
      "PowerShell(railway variables *--set*)",
      "PowerShell(railway variable set*)",
      "PowerShell(railway variable delete*)",
      "PowerShell(railway redeploy*)",
      "PowerShell(railway restart*)",
      "PowerShell(railway ssh*)",
      "PowerShell(railway volume add*)",
      "PowerShell(railway volume attach*)",
      "PowerShell(railway volume detach*)",
      "PowerShell(railway volume update*)",
      "PowerShell(railway agent*)",
      "PowerShell(pg_dump*)",
      "PowerShell(*Invoke-RestMethod*backboard.railway.app*)",
      "PowerShell(function New-*)",
      "PowerShell(*Add-Content*.env.cutover*)"
    ]
  }
}
