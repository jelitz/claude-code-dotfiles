{
  "skillListingBudgetFraction": 0.05,
  "env": {
    "CLAUDE_CODE_GIT_BASH_PATH": "C:\\Program Files\\Git\\bin\\bash.exe",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__claude-in-chrome__tabs_context_mcp",
      "PowerShell(*Get-FileHash*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "/c/Users/YOUR_USERNAME/.claude/statusline-bash.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "codex@openai-codex": true,
    "exa-core@exa-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "claude-mem@thedotmack": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "frontend-design@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "korean-law@korean-law-marketplace": false,
    "lazyweb@lazyweb": false,
    "cloudflare@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "exa-skills": {
      "source": {
        "source": "github",
        "repo": "benjaminjackson/exa-skills"
      }
    },
    "Claudest": {
      "source": {
        "source": "github",
        "repo": "gupsammy/claudest"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "korean-law-marketplace": {
      "source": {
        "source": "github",
        "repo": "chrisryugj/korean-law-mcp"
      }
    },
    "lazyweb": {
      "source": {
        "source": "git",
        "url": "https://github.com/aboul3ata/lazyweb-skill.git"
      }
    },
    "claude-for-financial-services": {
      "source": {
        "source": "github",
        "repo": "anthropics/financial-services"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "language": "Korean",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "normal",
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
